datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                 Int            @id @default(autoincrement())
  name               String
  accountType        String         // "current" | "savings" | "cash" | "credit" | "personal_loan" | "auto_loan"
  currency           String         @default("GBP")
  isActive           Boolean        @default(true)
  openingBalance     Float          @default(0)
  openingBalanceDate DateTime?
  creditLimit        Float?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  transactions       Transaction[]
  importRecords      ImportRecord[]
  incomingTransfers  Transaction[]  @relation("TransferCounterpart")
}

model ImportRecord {
  id               Int      @id @default(autoincrement())
  filename         String
  accountId        Int
  account          Account  @relation(fields: [accountId], references: [id])
  transactionCount Int
  importedAt       DateTime @default(now())
}

model Transaction {
  id                  Int           @id @default(autoincrement())
  date                DateTime
  amount              Float
  description         String        // human-readable display name (may be set by a pattern)
  originalDescription String?       // raw text from PDF/LLM before pattern substitution
  transactionType     String        @default("debit")  // "credit" | "debit" | "transfer"
  category            String        @default("")
  accountId           Int
  account             Account       @relation(fields: [accountId], references: [id])
  status              String        @default("review")  // "review" | "committed" | "reconciled"
  notes               String?
  rawSource           String?
  linkedTransferId    Int?
  linkedTransfer      Transaction?  @relation("TransferLink", fields: [linkedTransferId], references: [id])
  linkedFrom          Transaction[] @relation("TransferLink")
  parentTransactionId Int?
  parentTransaction   Transaction?  @relation("SplitLeg", fields: [parentTransactionId], references: [id])
  splitLegs           Transaction[] @relation("SplitLeg")
  reimbursableFor     String?                           // who owes the money back (e.g. "Insurance")
  reimbursementTxId   Int?          @unique             // settlement transaction id (one-to-one)
  reimbursementTx     Transaction?  @relation("ReimbursementLink", fields: [reimbursementTxId], references: [id], onDelete: SetNull)
  reimbursedExpense                Transaction?  @relation("ReimbursementLink")
  transferCounterpartAccountId     Int?
  transferCounterpartAccount       Account?      @relation("TransferCounterpart", fields: [transferCounterpartAccountId], references: [id], onDelete: SetNull)
  createdAt                        DateTime      @default(now())
  updatedAt                        DateTime      @updatedAt
}

model ChatSession {
  id        Int           @id @default(autoincrement())
  title     String        @default("New Chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        Int         @id @default(autoincrement())
  sessionId Int
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user" | "assistant"
  text      String
  sql       String?
  createdAt DateTime    @default(now())
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  color String @default("#6750A4")
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Budget {
  id           Int    @id @default(autoincrement())
  category     String @unique
  monthlyLimit Float
}

model VendorRule {
  id              Int     @id @default(autoincrement())
  pattern         String                          // no longer unique — multiple vendors can share a pattern
  matchType       String  @default("contains")    // "contains" | "starts-with" | "ends-with" | "exact" | "regex"
  vendor          String                          // display name to set on the transaction
  category        String                          // must match a Category.name
  direction       String  @default("either")      // "either" | "debit" | "credit"  — input gate
  transactionType String?                         // if set, overrides the inferred type: "credit" | "debit" | "transfer"
  minAmount       Float?                          // optional lower bound on abs(amount)
  maxAmount       Float?                          // optional upper bound on abs(amount)
  priority        Int     @default(0)             // lower number = higher priority
}
